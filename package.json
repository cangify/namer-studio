{
  "name": "aglove-video-renamer",
  "version": "0.1.0",
  "description": "Ai 视频自动命名工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "pack:win": "electron-builder --win zip",
    "pack:linux": "electron-builder --linux AppImage",
    "pack:mac": "electron-builder --mac zip"
  },
  "keywords": [
    "video",
    "ollama",
    "renamer"
  ],
  "author": "AGLove",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aglove.video-renamer",
    "productName": "Ai视频自动命名工具",
    "directories": {
      "output": "release-electron"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "zip"
      ],
      "icon": "src/assets/logo.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "src/assets/logo-256.png"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "src/assets/logo.png",
      "category": "public.app-category.utilities"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static-electron/**",
      "node_modules/ffprobe-static-electron/**"
    ]
  },
  "dependencies": {
    "ffmpeg-static-electron": "^2.0.3",
    "ffprobe-static-electron": "^2.0.2"
  }
}
